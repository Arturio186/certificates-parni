PORT=3000
NODE_ENV=development

# SMTP (Yandex)
SMTP_USER=your_email@yandex.ru
SMTP_PASSWORD=your_app_password
SMTP_FROM="Название Компании <your_email@yandex.ru>"

# YClients (на потом)
YCLIENTS_TOKEN=
YCLIENTS_COMPANY_ID=

# Защита от левых запросов (домены через запятую)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Игнорировать проверку домена локально
SKIP_ORIGIN_CHECK=true